<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D9D9D9"
    tools:context=".MapsEdit">

    <!-- Header atau judul Map -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView4"
        android:layout_width="match_parent"
        android:layout_height="67dp"
        app:cardBackgroundColor="#A4D99F"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textView2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="25dp"
            android:layout_marginTop="15dp"
            android:text="Map"
            android:textColor="#000000"
            android:textSize="25dp" />
    </androidx.cardview.widget.CardView>

    <!-- Tombol Kembali -->
    <ImageView
        android:id="@+id/imageView4"
        android:layout_width="25dp"
        android:layout_height="25dp"
        android:layout_marginTop="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardView4"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="16dp"
        app:srcCompat="@drawable/tombol_back" />

    <!-- Gambar atau preview peta -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/imageView3"
        android:layout_width="288dp"
        android:layout_height="153dp"
        android:layout_marginTop="8dp"
        android:scaleType="centerCrop"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toBottomOf="@+id/imageView4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:shapeAppearanceOverlay="@style/sm"
        app:srcCompat="@drawable/baseline_location_on_24" />

    <!-- Teks "Link Google Map" -->
    <TextView
        android:id="@+id/textView6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Link Google Map:"
        android:textColor="#000000"
        app:layout_constraintTop_toBottomOf="@id/imageView3"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginTop="16dp" />

    <!-- TextView yang berisi link dan bisa diklik -->
    <TextView
        android:id="@+id/textView7"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="https://maps.app.goo.gl/3gA4BiEBq2zRzxct7"
        android:textColor="#0000FF"
        android:textStyle="italic"
        android:autoLink="web"
        android:clickable="true"
        app:layout_constraintTop_toBottomOf="@id/textView6"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginStart="32dp"
        android:layout_marginTop="8dp" />

    <!-- Kartu untuk menampilkan dan mengedit Lokasi -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView7"
        android:layout_width="288dp"
        android:layout_height="45dp"
        app:cardBackgroundColor="#A4D99F"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/textView7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp">

        <!-- EditText untuk Lokasi -->
        <EditText
            android:id="@+id/etLokasi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gedung Widyaloka"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:background="@null"/>
    </androidx.cardview.widget.CardView>

    <!-- Kartu untuk menampilkan dan mengedit Kegiatan -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView6"
        android:layout_width="288dp"
        android:layout_height="45dp"
        app:cardBackgroundColor="#A4D99F"
        app:cardCornerRadius="20dp"
        app:layout_constraintTop_toBottomOf="@id/cardView7"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="16dp">

        <!-- EditText untuk Kegiatan -->
        <EditText
            android:id="@+id/etKegiatan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Diklat Pengurus"
            android:textColor="#FFFFFF"
            android:layout_marginLeft="20dp"
            android:layout_marginTop="10dp"
            android:background="@null"/>
    </androidx.cardview.widget.CardView>

    <!-- Tombol SIMPAN -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView8"
        android:layout_width="288dp"
        android:layout_height="45dp"
        app:cardBackgroundColor="#83AE7F"
        app:cardCornerRadius="20dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginBottom="44dp">

        <TextView
            android:id="@+id/textView11"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="110dp"
            android:layout_marginTop="8dp"
            android:text="SIMPAN"
            android:textSize="20dp" />
    </androidx.cardview.widget.CardView>

    <!-- Button untuk membuka kamera -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:clickable="true"
        app:layout_constraintBottom_toBottomOf="@+id/imageView3"
        app:layout_constraintEnd_toEndOf="@+id/imageView3"
        app:srcCompat="@drawable/baseline_camera_alt_24" />

</androidx.constraintlayout.widget.ConstraintLayout>
